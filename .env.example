# Database Configuration
DB_USER=apapi
DB_PASSWORD=apapi_secret
DB_NAME=apapi

# Security
SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters

# CORS
CORS_ORIGINS=http://localhost:3003

# Environment
ENVIRONMENT=development

# ── AI Provider Configuration ──────────────────────────────────────────────
# You can configure the AI provider here OR via the admin UI (Settings → AI tab).
# Admin UI settings take priority over .env values.
#
# Supported providers: anthropic, openai, google, groq, openrouter, ollama
LLM_PROVIDER=anthropic
LLM_MODEL=                        # Leave empty for provider default

# Anthropic (default provider)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (set LLM_PROVIDER=openai to use)
OPENAI_API_KEY=

# Google AI / Gemini (set LLM_PROVIDER=google to use)
GOOGLE_API_KEY=

# Groq (set LLM_PROVIDER=groq to use)
GROQ_API_KEY=

# OpenRouter (set LLM_PROVIDER=openrouter to use)
OPENROUTER_API_KEY=

# Ollama / Local (set LLM_PROVIDER=ollama to use)
# Ollama runs as a Docker service — no API key needed
OLLAMA_BASE_URL=http://ollama:11434

# ── Email Configuration ────────────────────────────────────────────────────
# Default: Mailpit (local email capture, no real emails sent)
# Web UI: http://localhost:8025  |  All emails are captured and viewable there.
# For production: configure via admin UI (Settings → Email tab) or override below.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@apapp.dev
SMTP_FROM_NAME=AP APP Assessment
SMTP_USE_TLS=false
FRONTEND_BASE_URL=http://localhost:3003

# ── Frontend Configuration ────────────────────────────────────────────────
# URL the frontend uses to reach the backend API (embedded at dev/build time)
VITE_API_URL=http://localhost:8003
