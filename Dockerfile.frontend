FROM node:20-slim

WORKDIR /app

# Install dependencies
# Workaround for npm bug where optional platform-specific deps (e.g. @rollup/rollup-linux-arm64-gnu)
# aren't installed when a package-lock.json built on a different platform is present.
COPY frontend/package*.json ./
RUN rm -f package-lock.json && npm install --include=optional

# Copy application code
COPY frontend/ .

# Expose port
EXPOSE 3000

# Default command
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
